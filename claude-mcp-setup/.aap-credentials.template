# AAP Credentials - AIOps Self-Healing Lab
#
# 1. Copie para seu home: cp .aap-credentials.template ~/.aap-credentials
# 2. Restrinja permissões: chmod 600 ~/.aap-credentials
# 3. Edite com suas credenciais reais
#
# Adicione ao ~/.zshrc ou ~/.bashrc:
#   if [ -f ~/.aap-credentials ]; then
#       source ~/.aap-credentials
#   fi

# URL do AAP Controller (sem trailing slash)
export AAP_SERVER="https://your-aap-instance.com"

# Token de API do AAP (Access Management → API Tokens)
export AAP_SERVICE_TOKEN="your-token-here"

# Desabilita verificação SSL para ambientes com certificado self-signed
# export NODE_TLS_REJECT_UNAUTHORIZED=0
